  "instructions": [
    {
      "name": "add_liquidity",
      "docs": [
        "Add liquidity to a Cubic Pool (proportional join)",
        "",
        "### Authority",
        "- \"liquidity_provider\" - The authority providing liquidity",
        "",
        "### Parameters",
        "- `token_amounts` - Array of token amounts to deposit",
        "- `minimum_bpt_amount` - Minimum BPT tokens to receive",
        "",
        "#### Special Errors",
        "- `InvalidAmounts` - Token amounts don't match pool composition",
        "- `InsufficientBptOut` - BPT minted less than minimum"
      ],
      "discriminator": [
        181,
        157,
        89,
        67,
        143,
        182,
        52,
        72
      ],
      "accounts": [
        {
