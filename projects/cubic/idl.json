    {
      "name": "initialize_cubic_pool",
      "docs": [
        "Initializes a Cubic Pool with virtual liquidity and weighted balances",
        "",
        "### Parameters",
        "- `tokens` - Array of token mints (2-10 tokens)",
        "- `normalized_weights` - Normalized weights in basis points (must sum to 10000)",
        "- `initial_virtual_balances` - Initial virtual balances for each token",
        "- `swap_fee_rate` - Swap fee rate (hundredths of basis point)",
        "",
        "#### Weight Examples",
        "- 50%/50% pool: [5000, 5000]",
        "- 80%/20% pool: [8000, 2000]",
        "- 33%/33%/34% pool: [3333, 3333, 3334]",
        "",
        "#### Special Errors",
        "- `InvalidTokenCount` - Token count must be between 2 and 10",
        "- `InvalidWeights` - Weights must sum to 10000",
        "- `InvalidVirtualBalances` - Virtual balances must be greater than zero"
      ],
      "discriminator": [
