            ],
            "type": {
              "array": [
                "pubkey",
                10
              ]
            }
          },
          {
            "name": "normalized_weights",
            "docs": [
              "Normalized weights in basis points (sum to WEIGHT_SCALE = 10000 = 100%)"
            ],
            "type": {
              "array": [
                "u64",
                10
              ]
            }
          },
          {
            "name": "virtual_balances",
