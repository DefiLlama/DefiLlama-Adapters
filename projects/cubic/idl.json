            "docs": [
              "Number of tokens in the pool (2-10)"
            ],
            "type": "u8"
          },
          {
            "name": "pool_id",
            "docs": [
              "Pool identifier / salt — allows multiple pools per config.",
              "PDA seeds: [CUBIC_POOL_SEED, config.key(), &pool_id.to_le_bytes()]"
            ],
            "type": "u64"
          },
          {
            "name": "token_mints",
            "docs": [
              "Token mints (up to 10)"
