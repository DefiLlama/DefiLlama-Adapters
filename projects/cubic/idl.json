            ],
            "type": "u32"
          },
          {
            "name": "protocol_fee_rate",
            "docs": [
              "Protocol fee rate in basis points (0 to 5000 = 50% of swap fee)"
            ],
            "type": "u16"
          },
          {
            "name": "protocol_fees_owed",
            "docs": [
